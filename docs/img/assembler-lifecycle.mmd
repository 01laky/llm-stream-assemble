		EA --> BUF
		EA --> TOOLS
		EA --> FIN
	end

	subgraph OUT["StreamEvent[]"]
		EV["text.* · tool_call.* · json.* · usage · finish"]
	end

	subgraph XFORM["Transforms — stateless"]
		TAP["tapEvents"]
		SSE["toSSE"]
		COL["collectStream"]
	end

	BYTES --> PC
	FIN --> EV
	EV --> TAP
	EV --> SSE
