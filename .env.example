# Google AI Gemini — optional live API key for scripts/live-smoke/gemini.ts
GOOGLE_API_KEY=
# GEMINI_API_KEY=   # alias accepted by the smoke script and node-fetch example
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_SMOKE_TOOLS=1   # run optional single-tool smoke after text prompt

# Vertex AI Gemini — pnpm smoke:vertex / examples/node-fetch/vertex-gemini.ts
# GOOGLE_CLOUD_PROJECT=
# VERTEX_LOCATION=us-central1
# VERTEX_MODEL=gemini-2.5-flash
# VERTEX_ACCESS_TOKEN=   # ADC bearer — e.g. gcloud auth application-default print-access-token

# Cohere Chat v2 — scripts/live-smoke/cohere-chat.mjs
# COHERE_API_KEY=
# COHERE_MODEL=command-r-plus-08-2024
# COHERE_SMOKE_TOOLS=1   # run optional single-tool smoke after text prompt

# AWS Bedrock — scripts/live-smoke/bedrock-converse.mjs
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_PROFILE=   # or SSO session — standard AWS credential chain

# OpenAI-compatible host presets — optional live smoke / examples
# OPENAI_COMPATIBLE_PROVIDER=generic   # groq | deepseek | mistral | ollama | openrouter | perplexity | xai | azure | …
# OPENAI_COMPATIBLE_BASE_URL=
# OPENAI_COMPATIBLE_API_KEY=
# OPENAI_COMPATIBLE_MODEL=

# DeepSeek — scripts/live-smoke/deepseek-compatible.mjs
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Groq / Mistral — use with examples/node-fetch/openai-compatible.ts
# GROQ_API_KEY=
# MISTRAL_API_KEY=

# LiteLLM — OpenAI-compatible proxy (also works with OPENAI_COMPATIBLE_* vars)
# LITELLM_BASE_URL=http://localhost:4000/v1
# LITELLM_API_KEY=
# LITELLM_MODEL=gpt-4o-mini

# Ollama — scripts/live-smoke/ollama-compatible.mjs (no API key)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2

# Perplexity — scripts/live-smoke/perplexity-compatible.mjs
# PERPLEXITY_API_KEY=
# PERPLEXITY_BASE_URL=https://api.perplexity.ai
# PERPLEXITY_MODEL=sonar

# xAI Grok — scripts/live-smoke/xai-compatible.mjs
# XAI_API_KEY=
# XAI_BASE_URL=https://api.x.ai/v1
# XAI_MODEL=grok-3

# Azure OpenAI — scripts/live-smoke/azure-openai-compatible.mjs
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_RESOURCE=
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=2024-10-21

# Cloudflare Workers AI — scripts/live-smoke/cloudflare-workers-ai-compatible.mjs
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct
