{
	"name": "llm-stream-assemble",
	"version": "1.10.2",
	"description": "Composable TypeScript stream assembly for OpenAI, Anthropic, Gemini (Google AI + Vertex AI), AWS Bedrock, Cohere, and OpenAI-compatible LLM APIs — unified StreamEvent model for text, tools, reasoning, JSON, usage, and non-streaming responses.",
	"license": "MIT",
	"author": "Ladislav Kostolny <01laky@gmail.com>",
	"type": "module",
	"sideEffects": false,
	"engines": {
		"node": ">=18"
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./core": {
			"types": "./dist/core/index.d.ts",
			"import": "./dist/core/index.js",
			"require": "./dist/core/index.cjs"
		},
		"./adapters/openai-chat": {
			"types": "./dist/adapters/openai-chat.d.ts",
			"import": "./dist/adapters/openai-chat.js",
			"require": "./dist/adapters/openai-chat.cjs"
		},
		"./adapters/openai-compatible": {
			"types": "./dist/adapters/openai-compatible.d.ts",
			"import": "./dist/adapters/openai-compatible.js",
			"require": "./dist/adapters/openai-compatible.cjs"
		},
		"./adapters/anthropic": {
			"types": "./dist/adapters/anthropic.d.ts",
			"import": "./dist/adapters/anthropic.js",
			"require": "./dist/adapters/anthropic.cjs"
		},
		"./adapters/openai-responses": {
			"types": "./dist/adapters/openai-responses.d.ts",
			"import": "./dist/adapters/openai-responses.js",
			"require": "./dist/adapters/openai-responses.cjs"
		},
		"./adapters/gemini": {
			"types": "./dist/adapters/gemini.d.ts",
			"import": "./dist/adapters/gemini.js",
			"require": "./dist/adapters/gemini.cjs"
		},
		"./adapters/bedrock": {
			"types": "./dist/adapters/bedrock.d.ts",
			"import": "./dist/adapters/bedrock.js",
			"require": "./dist/adapters/bedrock.cjs"
		},
		"./adapters/cohere": {
			"types": "./dist/adapters/cohere.d.ts",
			"import": "./dist/adapters/cohere.js",
			"require": "./dist/adapters/cohere.cjs"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"verify": "pnpm verify:deps && pnpm lint && pnpm typecheck && pnpm build && pnpm test && pnpm fixtures:check-compatible && pnpm fixtures:check-gemini && pnpm fixtures:check-responses-logprobs && pnpm fixtures:check-edge-catalog && pnpm fixtures:audit-registry && pnpm audit-edge-cases-catalog && pnpm smoke:package",
		"verify:deps": "node scripts/verify-zero-deps.mjs",
		"fixtures:generate-compatible": "node scripts/generate-compatible-preset-fixtures.mjs",
		"fixtures:check-compatible": "node scripts/generate-compatible-preset-fixtures.mjs --check",
		"fixtures:generate-gemini": "node scripts/generate-gemini-fixtures.mjs",
		"fixtures:check-gemini": "node scripts/generate-gemini-fixtures.mjs --check",
		"fixtures:generate-responses-logprobs": "node scripts/generate-openai-responses-logprob-fixtures.mjs",
		"fixtures:check-responses-logprobs": "node scripts/generate-openai-responses-logprob-fixtures.mjs --check",
		"fixtures:generate-edge-catalog": "node scripts/generate-edge-catalog-fixtures.mjs",
		"fixtures:check-edge-catalog": "npx tsx scripts/regenerate-edge-catalog-goldens.ts --check",
		"fixtures:audit-registry": "npx tsx scripts/audit-fixture-registry.ts --check",
		"audit-edge-cases-catalog": "npx tsx scripts/audit-edge-cases-catalog.ts --check",
		"smoke:package": "node scripts/smoke-package.mjs",
		"smoke:ollama": "node scripts/live-smoke/ollama-compatible.mjs",
		"smoke:deepseek": "node scripts/live-smoke/deepseek-compatible.mjs",
		"smoke:perplexity": "node scripts/live-smoke/perplexity-compatible.mjs",
		"smoke:xai": "node scripts/live-smoke/xai-compatible.mjs",
		"smoke:azure": "node scripts/live-smoke/azure-openai-compatible.mjs",
		"smoke:cloudflare": "node scripts/live-smoke/cloudflare-workers-ai-compatible.mjs",
		"smoke:bedrock": "node scripts/live-smoke/bedrock-converse.mjs",
		"smoke:cohere": "node scripts/live-smoke/cohere-chat.mjs",
		"smoke:gemini": "node scripts/live-smoke/gemini.mjs",
		"smoke:openai-logprobs": "node scripts/live-smoke/openai-chat-logprobs.mjs",
		"smoke:openai-responses-logprobs": "node scripts/live-smoke/openai-responses-logprobs.mjs",
		"smoke:vertex": "node scripts/live-smoke/vertex-gemini.mjs",
		"release:prep": "node scripts/release-prep.mjs",
		"diagrams:build": "node scripts/build-diagrams.mjs",
		"bench:smoke": "node scripts/bench-smoke.mjs"
	},
	"keywords": [
		"llm",
		"llm-stream",
		"streaming",
		"stream-assembly",
		"stream-events",
		"stream-parser",
		"sse",
		"sse-parser",
		"server-sent-events",
		"jsonl",
		"event-stream",
		"typescript",
		"composable",
		"openai",
		"openai-compatible",
		"openai-responses",
		"chat-completions",
		"anthropic",
		"messages-api",
		"gemini",
		"google",
		"google-ai",
		"google-cloud",
		"vertex-ai",
		"vertex",
		"azure-openai",
		"bedrock",
		"aws-bedrock",
		"converse-stream",
		"cohere",
		"ollama",
		"groq",
		"deepseek",
		"perplexity",
		"xai",
		"mistral",
		"together",
		"fireworks",
		"deepinfra",
		"cloudflare-workers",
		"structured-output",
		"json-mode",
		"reasoning",
		"tool-calling",
		"tool-use",
		"function-calling"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/01laky/llm-stream-assemble.git"
	},
	"bugs": {
		"url": "https://github.com/01laky/llm-stream-assemble/issues"
	},
	"homepage": "https://github.com/01laky/llm-stream-assemble#readme",
	"packageManager": "pnpm@9.15.9",
	"devDependencies": {
		"@aws-sdk/client-bedrock-runtime": "^3.826.0",
		"@eslint/js": "^9.28.0",
		"@types/node": "^22.15.29",
		"@vitest/coverage-v8": "^3.2.1",
		"eslint": "^9.28.0",
		"prettier": "^3.5.3",
		"tsup": "^8.5.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.33.0",
		"vitest": "^3.2.1"
	}
}
